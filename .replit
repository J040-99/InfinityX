modules = ["python-3.11"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Smoke test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Smoke test"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd InfinityX/InfinityX && python -c \"import py_compile, config, memory, utils, llm, actions, parser, infinityx; py_compile.compile('gui.py', doraise=True); print('InfinityX modulos importam OK + gui.py compila'); print('Acoes registradas:', sum(1 for n in dir(actions) if n.startswith('action_')))\""

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd InfinityX/InfinityX && python web_server.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 5000
externalPort = 80
